# Root monorepo
.env
.env.*
!.env.example
!**/.env.example
!**/.env.production.example
deploy/.env.production
deploy/vps.env
**/deploy/vps.env
**/deploy/.env.production
**/.env
**/.env.local
**/.env.production
**/.env.cpanel
**/.env.backup
!**/.env.example
# Never commit deploy artifacts / archives (may contain secrets)
deploy/output/
**/deploy/output/
*.zip
**/*.zip
node_modules/
**/node_modules/
dist/
**/dist/
vendor/
**/vendor/
.DS_Store
*.log
__pycache__/
**/__pycache__/
*.pyc
.idea/
.vscode/
E-learning-parrot-frontend/.git.bak/
E-learning-parrot-backend/.git.bak/
E-learning-parrot-backend/storage/logs/*
E-learning-parrot-backend/storage/framework/cache/*
E-learning-parrot-backend/storage/framework/sessions/*
E-learning-parrot-backend/storage/framework/views/*
E-learning-parrot-backend/bootstrap/cache/*.php
!E-learning-parrot-backend/bootstrap/cache/.gitignore
!E-learning-parrot-backend/storage/logs/.gitignore
docs/node_modules/
redeploy-branding.log
